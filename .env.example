# ============================================
# 拼团营销系统环境变量
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root_password_for_docker
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=group_buy_market

# --- Redis ---
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# --- RocketMQ ---
ROCKETMQ_NAME_SERVER=127.0.0.1:9876

# --- 支付宝沙箱（不填则使用 Mock 支付网关）---
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# --- 管理后台 ---
ADMIN_TOKEN=change-me
