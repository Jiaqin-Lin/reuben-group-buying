{
  "title": "拼团营销系统",
  "uid": "group-buy",
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "irate(groupbuy_requests_total[30s])",
          "legendFormat": "{{endpoint}}-{{code}}"
        }
      ],
      "title": "QPS 按接口",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, irate(groupbuy_request_duration_seconds_bucket[30s]))",
          "legendFormat": "P99-{{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.50, irate(groupbuy_request_duration_seconds_bucket[30s]))",
          "legendFormat": "P50-{{endpoint}}"
        }
      ],
      "title": "请求延迟",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "irate(groupbuy_cache_total{result=\"hit\"}[30s]) / irate(groupbuy_cache_total[30s])",
          "legendFormat": "命中率"
        }
      ],
      "title": "缓存命中率",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 9,
        "x": 6,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "irate(groupbuy_redis_total{result=\"ok\"}[30s])",
          "legendFormat": "{{operation}}-ok"
        }
      ],
      "title": "Redis 操作 QPS",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
